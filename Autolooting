local function updateVisuals()
    if LootConfig.Enabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(45, 160, 85)
        ToggleButton.Text = "AUTO: ON"
        startAutoLoot() 
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        ToggleButton.Text = "AUTO: OFF"
        stopAutoLoot() 
    end
end

ToggleButton.MouseButton1Click:Connect(function()
    LootConfig.Enabled = not LootConfig.Enabled
    updateVisuals()
end)

LockButton.MouseButton1Click:Connect(function()
    IsLocked = not IsLocked
    LockButton.Text = IsLocked and "🔒 LOCKED" or "🔓 UNLOCK"
    LockButton.TextColor3 = IsLocked and Color3.fromRGB(230, 90, 90) or Color3.fromRGB(200, 200, 200)
end)

local dragging, dragInput, dragStart, startPos

local function updateDrag(input)
    if IsLocked then return end
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

local function setupDragEvents(guiObject)
    guiObject.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not IsLocked then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    guiObject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
end

setupDragEvents(MainFrame)
setupDragEvents(LockButton)
setupDragEvents(ToggleButton)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then updateDrag(input) end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == TOGGLE_KEY then
        LootConfig.Enabled = not LootConfig.Enabled
        updateVisuals()
    end
end)

updateVisuals()
print("[AutoLoot] Đã vá lỗi nuốt mất Nhiên liệu/Tài nguyên.")
