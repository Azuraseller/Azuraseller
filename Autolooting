-- CẤU HÌNH TÙY CHỈNH
local TOGGLE_KEY = Enum.KeyCode.V  -- Phím tắt để Bật/Tắt Auto Loot
local LOOT_RANGE = 25              -- Khoảng cách tối đa để nhặt vật phẩm (Studs)

local LootConfig = {
    Enabled   = false,     -- [ĐÃ CẬP NHẬT] Mặc định ban đầu là false (Off) theo yêu cầu UI
    Guns      = true,      -- Tự động nhặt Súng
    Melee     = true,      -- Tự động nhặt Vũ khí cận chiến
    Medical   = true,      -- Tự động nhặt Thuốc men / Cứu thương
    Armor     = true,      -- Tự động nhặt Giáp
    Food      = true,      -- Tự động nhặt Đồ ăn thức uống
    Resources = true,      -- Tự động nhặt Tài nguyên chế tạo
    Ammo      = true,      -- Tự động nhặt Đạn dược
    Containers= true,      -- Tự động mở hòm gỗ / Thùng thính tiếp tế gần bên
}

-- SERVICES
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui") -- Thêm Service để chứa UI không bị mất khi chết

local LocalPlayer = Players.LocalPlayer

-- KIỂM TRA CỔNG GIAO TIẾP MẠNG (REMOTES)
local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
local pickUpItemRemote = Remotes and Remotes:FindFirstChild("Interaction") and Remotes.Interaction:FindFirstChild("PickUpItem")

if not pickUpItemRemote then
    warn("[AutoLoot] Không tìm thấy Remote Event 'PickUpItem'. Script có thể đã lỗi thời hoặc sai game.")
    return
end

-- DANH SÁCH VẬT PHẨM THEO PHÂN LOẠI (Dữ liệu từ Sodium HUB)
local ItemDatabase = {
    Gun = {
        "AA-12", "AK-47", "Assault Rifle", "Desert Eagle", "Double Barrel",
        "Flamethrower", "Grenade Launcher", "LMG", "MediGun", "Pistol",
        "Ray Gun", "Revolver", "Rifle", "Shotgun", "Sniper", "SVD", "Uzi"
    },
    Melee = {
        "Bat", "Chainsaw", "Crowbar", "Fire Axe", "Hatchet", "Katana", "Knife",
        "Riot Shield", "Scythe", "Sledgehammer", "Spear", "Spiked Bat"
    },
    Medical = {
        "Bandage", "Compound H", "Compound I", "Compound R", "Compound S", "Medkit"
    },
    Armor = {
        "Power Armor", "Light Armor", "Medium Armor", "Heavy Armor", "Basic Backpack", "Good Backpack", "Great Backpack"
    },
    Food = {
        "Chips", "Carrot", "Bloxiade", "Beans", "MRE", "Bloxy Cola"
    },
    Resource = {
        "AC", "Battery", "Battery Pack", "Bucket", "Dumbell", "Exhaust Pipe",
        "Reactor Component", "Refined Metal", "Satellite Dish", "Scrap",
        "Screws", "Spatula", "Tray", "TV", "Watch", "Zombie Heart", "Nuclear Fuel", "Refined Fuel", "Fuel",
        "Emerald", "Gas Mask", "Power Armor Arm", "Power Armor Core", "Radio Tower Part", "Blueprint", "Military Keycard", "Repair Hammer", "Suppressor"
    },
    Ammo = {
        "Ammo Box", "Long Ammo", "Medium Ammo", "Pistol Ammo", "Shells", "Ammo Crate"
    }
}

-- Chuyển đổi mảng thành bảng tra cứu nhanh O(1) để tối ưu hiệu năng
local FilterLookup = {}
for category, items in pairs(ItemDatabase) do
    for _, itemName in ipairs(items) do
        FilterLookup[itemName] = category
    end
end

-- Hàm kiểm tra xem vật phẩm này có được phép nhặt theo cấu hình không
local function shouldLootItem(itemName)
    local category = FilterLookup[itemName]
    if not category then return true end -- Nhặt luôn nếu là vật phẩm lạ không nằm trong danh sách
    
    if category == "Gun" and LootConfig.Guns then return true end
    if category == "Melee" and LootConfig.Melee then return true end
    if category == "Medical" and LootConfig.Medical then return true end
    if category == "Armor" and LootConfig.Armor then return true end
    if category == "Food" and LootConfig.Food then return true end
    if category == "Resource" and LootConfig.Resources then return true end
    if category == "Ammo" and LootConfig.Ammo then return true end
    
    return false
end

-- Hàm tìm phần vị trí chính của vật phẩm độc lập
local function getItemPart(item)
    if item:IsA("BasePart") then return item end
    if item.PrimaryPart then return item.PrimaryPart end
    return item:FindFirstChildWhichIsA("BasePart")
end

-- VÒNG LẶP CHÍNH XỬ LÝ AUTO LOOTING
task.spawn(function()
    while true do
        task.wait(0.3) -- Nghỉ 0.3 giây mỗi vòng quét để tránh làm quá tải đường truyền mạng (Spam Remote)
        
        if not LootConfig.Enabled then continue end
        
        local character = LocalPlayer.Character
        local rootPart = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
        if not rootPart then continue end
        
        -- 1. XỬ LÝ NHẶT ĐỒ TRÊN MẶT ĐẤT (Dropped Items)
        local droppedFolder = Workspace:FindFirstChild("DroppedItems")
        if droppedFolder then
            for _, item in ipairs(droppedFolder:GetChildren()) do
                if item:IsA("Model") and shouldLootItem(item.Name) then
                    local part = getItemPart(item)
                    if part then
                        local distance = (rootPart.Position - part.Position).Magnitude
                        if distance <= LOOT_RANGE then
                            pcall(function()
                                pickUpItemRemote:FireServer(item)
                            end)
                        end
                    end
                end
            end
        end
        
        -- 2. XỬ LÝ TỰ ĐỘNG MỞ HÒM GẦN BÊN (Auto Containers)
        if LootConfig.Containers then
            local structuresFolder = Workspace:FindFirstChild("Structures") 
                or Workspace:FindFirstChild("PlayerStructures") 
                or Workspace:FindFirstChild("Buildings")
                
            if structuresFolder then
                for _, struct in ipairs(structuresFolder:GetChildren()) do
                    -- Tìm các hòm tiếp tế hoặc hòm chứa đồ có cơ chế tương tác mở
                    if struct:IsA("Model") and (string.find(struct.Name:lower(), "crate") or string.find(struct.Name:lower(), "container") or string.find(struct.Name:lower(), "supply")) then
                        local part = getItemPart(struct)
                        if part then
                            local distance = (rootPart.Position - part.Position).Magnitude
                            if distance <= LOOT_RANGE then
                                -- Giả lập gửi tín hiệu mở hoặc nhặt bên trong hòm tương tự cơ chế nhặt vật phẩm
                                pcall(function()
                                    pickUpItemRemote:FireServer(struct)
                                end)
                            end
                        end
                    end
                end
            end
        end
        
    end
end)

-- THÔNG BÁO TRÊN MÀN HÌNH KHI CHẠY SCRIPT
local function sendNotification(title, message)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = message,
            Duration = 3
        })
    end)
end

