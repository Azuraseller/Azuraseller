local FilterLookup = {}
for category, items in pairs(ItemDatabase) do
    for _, itemName in ipairs(items) do FilterLookup[itemName] = category end
end

local BlacklistRemote = {
    ["Chips"] = true, ["Carrot"] = true, ["Bloxiade"] = true, ["Beans"] = true, ["MRE"] = true, ["Bloxy Cola"] = true,
    ["Nuclear Fuel"] = true, ["Refined Fuel"] = true, ["Fuel"] = true,
    ["Power Armor Arm"] = true, ["Power Armor Core"] = true, ["Radio Tower Part"] = true,
    ["AC"] = true, ["Battery"] = true, ["Battery Pack"] = true, ["Bucket"] = true, ["Dumbell"] = true, ["Exhaust Pipe"] = true,
    ["Reactor Component"] = true, ["Refined Metal"] = true, ["Satellite Dish"] = true, ["Scrap"] = true, ["Screws"] = true,
    ["Spatula"] = true, ["Tray"] = true, ["TV"] = true, ["Watch"] = true, ["Zombie Heart"] = true,
    ["Airstrike"] = true, ["Attack Order"] = true, ["Call of the Dead"] = true, ["Summon Brute"] = true,
    ["Summon Zombies"] = true, ["Taunt"] = true, ["The Future"] = true, ["The Past"] = true, ["The Present"] = true,
}

local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
local pickUpItemRemote = Remotes and Remotes:FindFirstChild("Interaction") and Remotes.Interaction:FindFirstChild("PickUpItem")
local adjustBackpackRemote = Remotes and Remotes:FindFirstChild("Tools") and Remotes.Tools:FindFirstChild("AdjustBackpack")

local function getValidRootPart()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
end

local function shouldLootItem(item)
    if not item or not item.Name then return false end
    local cleanName = string.gsub(item.Name, "%s*[%d%a]+$", "") 
    local category = FilterLookup[cleanName] or FilterLookup[item.Name]
    if string.find(item.Name:lower(), "backpack") then category = "Armor" end
    if not category then return true end 
    if category == "Gun" and LootConfig.Guns then return true end
    if category == "Melee" and LootConfig.Melee then return true end
    if category == "Medical" and LootConfig.Medical then return true end
    if category == "Armor" and LootConfig.Armor then return true end
    if category == "Food" and LootConfig.Food then return true end
    if category == "Resource" and LootConfig.Resources then return true end
    if category == "Ammo" and LootConfig.Ammo then return true end
    return false
end

