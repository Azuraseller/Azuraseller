local MenuExpanded = false
local SpeedExtraExpanded = false
local AuraExtraExpanded = false
local IsLocked = false

local function updateMenuSize()
    local targetHeight = 32
    local targetWidth = 115 
    
    if MenuExpanded then
        targetWidth = 195
        targetHeight = 96 -- Chứa Row 1, Row 2, Row 5
        Row2.Visible = true
        Row5.Visible = true
        
        if SpeedExtraExpanded then 
            targetHeight = targetHeight + 64 -- Thêm Row 3, Row 4
            Row3.Visible = true
            Row4.Visible = true
        end
    end
    
    TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, targetWidth, 0, targetHeight)}):Play()
    
    if not MenuExpanded then
        task.delay(0.2, function()
            if not MenuExpanded then
                Row2.Visible = false
                Row3.Visible = false
                Row4.Visible = false
                Row5.Visible = false
                BtnLock.Visible = false
                BtnAutoLoot.Size = UDim2.new(1, -25, 1, 0)
            end
        end)
    else
        BtnLock.Visible = true
        BtnAutoLoot.Size = UDim2.new(1, -90, 1, 0)
    end
end

