-- ============================================
-- 3. HÀM XỬ LÝ CHỨC NĂNG
-- ============================================

-- A. AutoLoot Core
local autoPickupThread = nil
local function stopAutoLoot()
    if autoPickupThread then pcall(function() task.cancel(autoPickupThread) end) autoPickupThread = nil end
end

local function startAutoLoot()
    stopAutoLoot()
    autoPickupThread = task.spawn(function()
        while LootConfig.Enabled do 
            task.wait(0.2) 
            local hrp = getValidRootPart()
            if not hrp then continue end

            local droppedFolder = Workspace:FindFirstChild("DroppedItems")
            if droppedFolder then
                for _, item in ipairs(droppedFolder:GetChildren()) do
                    if not LootConfig.Enabled then break end 
                    if (item:IsA("Model") or item:IsA("BasePart")) and shouldLootItem(item) then
                        local mainPart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
                        if mainPart and (hrp.Position - mainPart.Position).Magnitude <= LOOT_RANGE then
                            if not BlacklistRemote[item.Name] then
                                pcall(function() if pickUpItemRemote then pickUpItemRemote:FireServer(item) end end)
                            end
                            pcall(function() if adjustBackpackRemote then adjustBackpackRemote:FireServer(item) end end)
                            pcall(function()
                                if firetouchinterest then
                                    firetouchinterest(hrp, mainPart, 0)
                                    firetouchinterest(hrp, mainPart, 1)
                                end
                            end)
                        end
                    end
                end
            end
        end
    end)
end

-- B. NoClip
local function toggleNoClip(state)
    State.NoClip = state
    if Connections.NoClip then Connections.NoClip:Disconnect() Connections.NoClip = nil end
    noclipLastCFrame = nil
    if state then
        Connections.NoClip = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not root then noclipLastCFrame = nil return end

            local currentCF = root.CFrame
            if noclipLastCFrame then
                local delta = (currentCF.Position - noclipLastCFrame.Position).Magnitude
                if delta > 8 then
                    root.CFrame = noclipLastCFrame
                    currentCF  = noclipLastCFrame
                end
            end
            noclipLastCFrame = currentCF
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end)
    end
end

-- C. SpeedHack & Bypass Logic 
local speedBypassThread = nil
local function updateSpeedLogic()
    if Connections.SpeedLoop then Connections.SpeedLoop:Disconnect() Connections.SpeedLoop = nil end
    if speedBypassThread then task.cancel(speedBypassThread) speedBypassThread = nil end

    Connections.SpeedLoop = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.WalkSpeed = targetWalkSpeed end
    end)

    if State.SpeedMode == 0 then
        targetWalkSpeed = 16
        if Connections.SpeedLoop then Connections.SpeedLoop:Disconnect() end
        local char = LocalPlayer.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.WalkSpeed = 16 end
    elseif State.SpeedMode == 1 then
        targetWalkSpeed = State.CustomSpeed
    elseif State.SpeedMode == 2 then
        speedBypassThread = task.spawn(function()
            while State.SpeedMode == 2 do
                targetWalkSpeed = 16
                task.wait(1)
                if State.SpeedMode ~= 2 then break end
                targetWalkSpeed = State.CustomBypass
                task.wait(0.75)
            end
        end)
    end
end

-- D. Kill Aura (Loại bỏ Auto-Equip, đánh diện rộng dựa theo Safe Mode)
local killAuraThread = nil
local function toggleKillAura(state)
    State.KillAura = state
    if killAuraThread then task.cancel(killAuraThread) killAuraThread = nil end
    if state then
        killAuraThread = task.spawn(function()
            while State.KillAura do
                task.wait(State.SafeModeDelay)
                local char = LocalPlayer.Character
                if not char then continue end
                
                -- Yêu cầu người chơi tự cầm vũ khí
                local tool = char:FindFirstChildOfClass("Tool")
                if not tool or not tool:FindFirstChild("Handle") then continue end 
                
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then continue end

                local zombiesFolder = Workspace:FindFirstChild("Zombies") or Workspace:FindFirstChild("Mobs") or Workspace
                
                for _, obj in ipairs(zombiesFolder:GetChildren()) do
                    if obj ~= char and obj:IsA("Model") then
                        local mobHrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                        local mobHum = obj:FindFirstChildOfClass("Humanoid")
                        if mobHrp and mobHum and mobHum.Health > 0 then
                            local dist = (hrp.Position - mobHrp.Position).Magnitude
                            if dist <= 20 then
                                pcall(function()
                                    if firetouchinterest then
                                        firetouchinterest(tool.Handle, mobHrp, 0)
                                        firetouchinterest(tool.Handle, mobHrp, 1)
                                    end
                                end)
                            end
                        end
                    end
                end
            end
        end)
    end
end

-- E. Inf Jump & Bhop
local function toggleInfJump(state)
    State.InfJump = state
    if Connections.InfJump then Connections.InfJump:Disconnect() Connections.InfJump = nil end
    if state then
        Connections.InfJump = UserInputService.JumpRequest:Connect(function()
            local char = LocalPlayer.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
    end
end

local function toggleBhop(state)
    State.Bhop = state
    if Connections.Bhop then Connections.Bhop:Disconnect() Connections.Bhop = nil end
    if state then
        Connections.Bhop = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            if not humanoid then return end
            if humanoid.MoveDirection.Magnitude > 0.1 then
                local state = humanoid:GetState()
                if state == Enum.HumanoidStateType.Running or state == Enum.HumanoidStateType.RunningNoPhysics then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    end
end

