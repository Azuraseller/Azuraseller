local LocalPlayer = Players.LocalPlayer

local TOGGLE_KEY = Enum.KeyCode.V
local LOOT_RANGE = 25

local LootConfig = {
    Enabled   = false,
    Guns      = true, Melee = true, Medical = true, Armor = true,
    Food      = true, Resources = true, Ammo = true, Containers = true,
}

local ItemDatabase = {
    Gun = {"AA-12", "AK-47", "Assault Rifle", "Desert Eagle", "Double Barrel", "Flamethrower", "Grenade Launcher", "LMG", "MediGun", "Pistol", "Ray Gun", "Revolver", "Rifle", "Shotgun", "Sniper", "SVD", "Uzi"},
    Melee = {"Bat", "Chainsaw", "Crowbar", "Fire Axe", "Hatchet", "Katana", "Knife", "Riot Shield", "Scythe", "Sledgehammer", "Spear", "Spiked Bat"},
    Medical = {"Bandage", "Compound H", "Compound I", "Compound R", "Compound S", "Medkit"},
    Armor = {"Power Armor", "Light Armor", "Medium Armor", "Heavy Armor", "Basic Backpack", "Good Backpack", "Great Backpack"},
    Food = {"Chips", "Carrot", "Bloxiade", "Beans", "MRE", "Bloxy Cola"},
    Resource = {"AC", "Battery", "Battery Pack", "Bucket", "Dumbell", "Exhaust Pipe", "Reactor Component", "Refined Metal", "Satellite Dish", "Scrap", "Screws", "Spatula", "Tray", "TV", "Watch", "Zombie Heart", "Nuclear Fuel", "Refined Fuel", "Fuel", "Emerald", "Gas Mask", "Power Armor Arm", "Power Armor Core", "Radio Tower Part", "Blueprint", "Military Keycard", "Repair Hammer", "Suppressor"},
    Ammo = {"Ammo Box", "Long Ammo", "Medium Ammo", "Pistol Ammo", "Shells", "Ammo Crate"}
}

local FilterLookup = {}
for category, items in pairs(ItemDatabase) do
    for _, itemName in ipairs(items) do FilterLookup[itemName] = category end
end

-- DANH SÁCH ĐEN TÍN HIỆU (Chống ăn mất đồ)
local BlacklistRemote = {
    ["Chips"] = true, ["Carrot"] = true, ["Bloxiade"] = true, ["Beans"] = true, ["MRE"] = true, ["Bloxy Cola"] = true,
    ["Nuclear Fuel"] = true, ["Refined Fuel"] = true, ["Fuel"] = true,
    ["Power Armor Arm"] = true, ["Power Armor Core"] = true, ["Radio Tower Part"] = true,
    ["AC"] = true, ["Battery"] = true, ["Battery Pack"] = true, ["Bucket"] = true, ["Dumbell"] = true, ["Exhaust Pipe"] = true,
    ["Reactor Component"] = true, ["Refined Metal"] = true, ["Satellite Dish"] = true, ["Scrap"] = true, ["Screws"] = true,
    ["Spatula"] = true, ["Tray"] = true, ["TV"] = true, ["Watch"] = true, ["Zombie Heart"] = true,
    ["Airstrike"] = true, ["Attack Order"] = true, ["Call of the Dead"] = true, ["Summon Brute"] = true,
    ["Summon Zombies"] = true, ["Taunt"] = true, ["The Future"] = true, ["The Past"] = true, ["The Present"] = true,
}

local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
local pickUpItemRemote = Remotes and Remotes:FindFirstChild("Interaction") and Remotes.Interaction:FindFirstChild("PickUpItem")
local adjustBackpackRemote = Remotes and Remotes:FindFirstChild("Tools") and Remotes.Tools:FindFirstChild("AdjustBackpack")

local function getValidRootPart()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") 
        or char:FindFirstChild("UpperTorso") 
        or char:FindFirstChild("Torso") 
        or char:FindFirstChildWhichIsA("BasePart")
end

local function shouldLootItem(item)
    if not item or not item.Name then return false end
    local name = item.Name
    local cleanName = string.gsub(name, "%s*[%d%a]+$", "") 
    local category = FilterLookup[cleanName] or FilterLookup[name]
    
    if string.find(name:lower(), "backpack") then category = "Armor" end
    if not category then return true end 
    
    if category == "Gun" and LootConfig.Guns then return true end
    if category == "Melee" and LootConfig.Melee then return true end
    if category == "Medical" and LootConfig.Medical then return true end
    if category == "Armor" and LootConfig.Armor then return true end
    if category == "Food" and LootConfig.Food then return true end
    if category == "Resource" and LootConfig.Resources then return true end
    if category == "Ammo" and LootConfig.Ammo then return true end
    return false
end

local autoPickupThread = nil

local function stopAutoLoot()
    if autoPickupThread then
        pcall(function() task.cancel(autoPickupThread) end)
        autoPickupThread = nil
    end
end

local function startAutoLoot()
    stopAutoLoot()
    autoPickupThread = task.spawn(function()
        while LootConfig.Enabled do 
            task.wait(0.2) 
            
            local hrp = getValidRootPart()
            if not hrp then continue end

            local droppedFolder = Workspace:FindFirstChild("DroppedItems")
            if droppedFolder then
                for _, item in ipairs(droppedFolder:GetChildren()) do
                    if not LootConfig.Enabled then break end 
                    
                    if (item:IsA("Model") or item:IsA("BasePart")) and shouldLootItem(item) then
                        local mainPart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
                        if mainPart and (hrp.Position - mainPart.Position).Magnitude <= LOOT_RANGE then
                            
                            -- FIX LỖI Ở ĐÂY: Chỉ gửi tín hiệu trực tiếp nếu vật phẩm KHÔNG CÓ trong danh sách đen
                            if not BlacklistRemote[item.Name] then
                                pcall(function() if pickUpItemRemote then pickUpItemRemote:FireServer(item) end end)
                            end
                            
                            -- Lệnh cất đồ vào balo thì luôn chạy cho mọi vật phẩm
                            pcall(function() if adjustBackpackRemote then adjustBackpackRemote:FireServer(item) end end)

                            pcall(function()
                                if firetouchinterest then
                                    firetouchinterest(hrp, mainPart, 0)
                                    firetouchinterest(hrp, mainPart, 1)
                                end
                            end)

                            pcall(function()
                                if fireproximityprompt then
                                    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                                    if prompt then fireproximityprompt(prompt) end
                                end
                            end)
                        end
                    end
                end
            end
            
            if LootConfig.Containers then
                local structuresFolder = Workspace:FindFirstChild("Structures") 
                    or Workspace:FindFirstChild("PlayerStructures") 
                    or Workspace:FindFirstChild("Buildings")
                    
                if structuresFolder then
                    for _, struct in ipairs(structuresFolder:GetChildren()) do
                        if not LootConfig.Enabled then break end
                        
                        if struct:IsA("Model") and (string.find(struct.Name:lower(), "crate") or string.find(struct.Name:lower(), "container") or string.find(struct.Name:lower(), "supply")) then
                            local mainPart = struct.PrimaryPart or struct:FindFirstChildWhichIsA("BasePart")
                            if mainPart and (hrp.Position - mainPart.Position).Magnitude <= LOOT_RANGE then
                                pcall(function() if pickUpItemRemote then pickUpItemRemote:FireServer(struct) end end)
                                pcall(function()
                                    if fireproximityprompt then
                                        local prompt = struct:FindFirstChildWhichIsA("ProximityPrompt", true)
                                        if prompt then fireproximityprompt(prompt) end
                                    end
                                end)
                            end
                        end
                    end
                end
            end
        end
    end)
end

