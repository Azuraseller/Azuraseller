-- Hàm cập nhật đồng bộ trạng thái màu sắc và văn bản của Công tắc
local function updateVisuals()
    if LootConfig.Enabled then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(45, 160, 85) -- Xanh lá khi ON
        ToggleButton.Text = "AUTO: ON"
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50) -- Đỏ khi OFF
        ToggleButton.Text = "AUTO: OFF"
    end
end

-- Sự kiện nhấn nút Công tắc để Bật/Tắt AutoLoot
ToggleButton.MouseButton1Click:Connect(function()
    LootConfig.Enabled = not LootConfig.Enabled
    updateVisuals()
    local status = LootConfig.Enabled and "Đã BẬT 🟢" or "Đã TẤT 🔴"
    sendNotification("Auto Loot UI", "Chức năng Tự động nhặt đồ " .. status)
end)

-- Sự kiện nhấn nút Khóa/Mở Khóa kéo thả menu
LockButton.MouseButton1Click:Connect(function()
    IsLocked = not IsLocked
    if IsLocked then
        LockButton.Text = "🔒 LOCKED"
        LockButton.TextColor3 = Color3.fromRGB(230, 90, 90)
    else
        LockButton.Text = "🔓 UNLOCK"
        LockButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

-- LOGIC KÉO THẢ TỰ DO BẰNG CHUỘT HOẶC NGÓN TAY TRÊN DI ĐỘNG (Chỉ hoạt động khi UNLOCK)
local dragging
local dragInput
local dragStart
local startPos

local function update(input)
    if IsLocked then return end -- Nếu đang ở trạng thái Khóa (LOCKED), không cho phép di chuyển
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not IsLocked then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- LẮNG NGHE SỰ KIỆN ẤN PHÍM TẮT ĐỂ ĐỒNG BỘ VỚI MENU UI KHÁCH
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == TOGGLE_KEY then
        LootConfig.Enabled = not LootConfig.Enabled
        updateVisuals()
        local status = LootConfig.Enabled and "Đã BẬT 🟢" or "Đã TẤT 🔴"
        sendNotification("Auto Loot Standalone", "Chức năng Tự động nhặt đồ " .. status)
    end
end)

-- KHỞI CHẠY THIẾT LẬP BAN ĐẦU
updateVisuals() -- Đồng bộ giao diện về trạng thái OFF ban đầu
sendNotification("Auto Loot Loaded", "Ấn phím '".. TOGGLE_KEY.Name .."' hoặc dùng Menu để Bật/Tắt Auto Looting!")
